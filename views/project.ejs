<h2>我的作品列表</h2>

<ul>
  <% projects.forEach(project => { %>
    <li>
      <h3><%= project.title %></h3>
      <p><%= project.description %></p>
      <iframe src="<%= project.scratchLink %>" width="485" height="402" allowfullscreen></iframe>
    </li>
  <% }) %>
</ul>

<h2>新增作品</h2>
<form action="/projects" method="POST">
  <input type="text" name="title" placeholder="作品名稱" required>
  <input type="text" name="description" placeholder="作品簡介">
  <input type="text" name="scratchLink" placeholder="Scratch 作品連結" required>
  <button type="submit">新增作品</button>
</form>

